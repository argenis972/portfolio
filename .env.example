# ============================================
# ENVIRONMENT VARIABLES EXAMPLE
# ============================================
#
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Fill in the real values
# 3. NEVER commit the .env file
#
# Command: cp .env.example .env
# ============================================

# ===========================
# ENVIRONMENT
# ===========================
AMBIENTE=development
# Possible values: development, staging, production

# ===========================
# BACKEND - API
# ===========================

# Server
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# CORS - Allowed Origins (comma separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175
# Production: https://your-domain.com

# Versioning
API_VERSION=1.0.0

# ===========================
# E-MAIL (for contact form)
# ===========================

# SMTP Server
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true

# Credentials (use App Password if Gmail)
EMAIL_REMETENTE=youremail@gmail.com
EMAIL_SENHA=your_app_password_here

# Contacts recipient
EMAIL_DESTINO=youremail@gmail.com

# ===========================
# DATABASE (future)
# ===========================

# PostgreSQL (Production or Docker)
DATABASE_URL=postgresql+asyncpg://portfolio:secure_password_here@localhost:5432/portfolio_db
POSTGRES_PASSWORD=secure_password_here
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ===========================
# AUTHENTICATION (future)
# ===========================

# JWT
# SECRET_KEY=super-secure-secret-key-here-use-openssl-rand-hex-32
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===========================
# LOGGING AND MONITORING
# ===========================

# Log level
LOG_LEVEL=INFO
# Values: DEBUG, INFO, WARNING, ERROR, CRITICAL

# -----------------------------------------------------------
# OBSERVABILITY (Tier 1 — Sentry + Prometheus + OTel)
# -----------------------------------------------------------

# Password for Grafana admin panel in docker-compose
GRAFANA_ADMIN_PASSWORD=secret_admin

# Sentry — Error Tracking & Performance Monitoring
# Obtain at: sentry.io > Project Settings > Client Keys (DSN)
# Leave empty to disable (development/tests)
SENTRY_DSN=

# Percentage of transactions sent to Sentry (0.0 to 1.0)
# 0.2 = 20% of requests. In production, 0.1-0.2 is recommended.
SENTRY_TRACES_SAMPLE_RATE=0.2

# OpenTelemetry — Distributed Tracing
# OTLP Endpoint for trace submission (Jaeger, Grafana Tempo, Honeycomb...)
# Leave empty to use ConsoleExporter (prints to stdout, useful in dev)
# Local Jaeger (via docker-compose): http://localhost:4318
OTLP_ENDPOINT=

# Prometheus Metrics
# Enables the endpoint GET /metrics (scraped by Prometheus)
PROMETHEUS_HABILITADO=true

# ===========================
# CACHE (future)
# ===========================

# Redis (Rate Limiting and Cache)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# ===========================
# STORAGE (future)
# ===========================

# AWS S3 (for image uploads)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_S3_BUCKET=bucket-name
# AWS_REGION=us-east-1

# ===========================
# FRONTEND
# ===========================

# API URL
VITE_API_URL=http://localhost:8000/api/v1
# Production: https://api.your-domain.com/api/v1

# Chaos Engineering UI
# The Chaos Playground and Trace Viewer are enabled by default in the current build.

# Google Analytics (future)
# VITE_GA_TRACKING_ID=UA-XXXXXXXXX-X

# ===========================
# INFRASTRUCTURE (Terraform)
# ===========================

# Koyeb API Token (Required for Terraform provisioning)
# Obtain at: Koyeb > Organization Settings > API Keys
# TF_VAR_koyeb_token=your_koyeb_api_token_here

# ===========================
# FEATURE FLAGS (future)
# ===========================

# ENABLE_BLOG=false
# ENABLE_NEWSLETTER=false
# ENABLE_COMMENTS=false
