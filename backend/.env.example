NOME_APP="Portfólio Backend API"
AMBIENTE="local"
ORIGENS_PERMITIDAS="http://localhost:5173,http://127.0.0.1:5173"
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"
RESEND_TO_EMAIL=""
DATABASE_URL="sqlite+aiosqlite:///./dev.db"

# --- Observability ---
# Sentry DSN (Key). Leave empty to disable Sentry.
SENTRY_DSN=""
# Tracking sampling (0.0 to 1.0). 1.0 is 100%.
SENTRY_TRACES_SAMPLE_RATE=0.2
# OTLP Endpoint (Optional, for Jaeger or Grafana Tempo). Do not use Sentry here.
OTLP_ENDPOINT=""

# Regex to allow Vercel subdomains in CORS (Branch Previews)
REGEX_ORIGENS_PERMITIDAS=^https://portfolio.*-argenis1412s-projects\.vercel\.app$
